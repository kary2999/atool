{
  "manifest_version": 3,
  "name": "Atool — WebSocket + 开发工具箱",
  "version": "2.1.0",
  "description": "WebSocket 抓包/解压/调试 + 多语言翻译 SQL 生成与检索 — DevTools 嵌入 & 独立侧栏",
  "permissions": ["sidePanel"],
  "host_permissions": ["https://translate.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "devtools_page": "devtools.html",
  "side_panel": {
    "default_path": "panel.html"
  },
  "action": {
    "default_title": "Atool（点击打开侧栏）",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
